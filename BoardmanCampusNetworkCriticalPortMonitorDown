{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.2",
  "body": [
    {
      "type": "TextBlock",
      "text": "🚨 Alert Triggered: @{triggerBody()?['nodeName']} port @{triggerBody()?['Port']} is down!",
      "weight": "Bolder",
      "wrap": true,
      "size": "Large",
      "color": "@{if(equals(triggerBody()?['status'],'Down'),'Attention','Good')}"
    },
    {
      "type": "TextBlock",
      "text": "Alert triggered on monitored port",
      "isSubtle": true,
      "spacing": "None"
    },
    {
      "type": "FactSet",
      "spacing": "Medium",
      "facts": [
        {
          "title": "Node",
          "value": "@{triggerBody()?['nodeName']}"
        },
                {
          "title": "Port",
          "value": "@{triggerBody()?['Port']}"
        },
        {
          "title": "Status",
          "value": "**@{triggerBody()?['status']}**"
        },
        {
          "title": "IP Address",
          "value": "@{triggerBody()?['ipAddress']}"
        },
        {
          "title": "Alert Time",
          "value": "@{triggerBody()?['alertTime']}"
        },
      {
          "title": "View alerting Port",
          "value": "@{triggerBody()?['PortURL']}"
        },
      {
          "title": "Click to Acknowledge",
          "value": "@{triggerBody()?['Ack']}"
        },
     {
          "title": "Message Sent by Alert Named:",
          "value": "@{triggerBody()?['AlertName']}"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open Orion",
      "url": "https://orion.hvfcu.org"
    }
  ]
}


{
  "nodeName": "${N=SwisEntity;M=Node.Caption}",
  "Port": "${N=SwisEntity;M=Caption}",
  "status": "${N=SwisEntity;M=Status}",
  "alertTime": "${N=Alerting;M=AlertTriggerTime;F=yyyy-MM-dd HH:mm:ss}",
  "ipAddress": "${N=SwisEntity;M=IP_Address}",
  "PortURL": "${N=Alerting;M=AlertDetailsUrl}",
  "AlertName": "${N=Alerting;M=AlertName}",
  "Ack":  "${N=Alerting;M=AcknowledgeUrl}"
}