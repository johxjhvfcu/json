{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.2",
  "body": [
    {
      "type": "TextBlock",
      "text": "🚨 SolarWinds Orion Alert",
      "weight": "Bolder",
      "size": "Large",
      "color": "@{if(equals(triggerBody()?['status'],'Down'),'Attention','Good')}"
    },
    {
      "type": "TextBlock",
      "text": "Alert triggered on monitored node",
      "isSubtle": true,
      "spacing": "None"
    },
    {
      "type": "FactSet",
      "spacing": "Medium",
      "facts": [
        {
          "title": "Node",
          "value": "@{triggerBody()?['nodeName']}"
        },
        {
          "title": "Status",
          "value": "**@{triggerBody()?['status']}**"
        },
        {
          "title": "IP Address",
          "value": "@{triggerBody()?['ipAddress']}"
        },
        {
          "title": "Alert Time",
          "value": "@{triggerBody()?['alertTime']}"
        },
      {
          "title": "View alerting Node",
          "value": "@{triggerBody()?['NodeURL']}"
        },
      {
          "title": "Click to Acknowledge",
          "value": "@{triggerBody()?['Ack']}"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open Orion",
      "url": "https://orion.hvfcu.org"
    }
  ]
}